# 环境配置示例文件
# 复制此文件为 .env 并填写实际值
# ⚠️ 注意：.env 文件包含敏感信息，切勿上传到 Git！

# Flask 配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置（开发环境 - MySQL）
DB_HOST=localhost
DB_USER=doguser
DB_PASSWORD=123456
DB_NAME=dog

# JWT 配置
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 生产环境部署时（Railway/Render），只需设置：
# FLASK_ENV=production
# SECRET_KEY=<随机生成的密钥>
# DATABASE_URL=<云平台自动提供>
# ADMIN_PASSWORD=admin123
