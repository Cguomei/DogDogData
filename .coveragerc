[run]
source = .
omit =
    Test/*
    conftest.py
    */venv/*
    */site-packages/*
    */migrations/*
    setup.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

fail_under = 70
